Diagrama Biblioteca.

posicion Recurso {
X=50;
Y=50;
}

posicion Libro {
X=50;
Y=300;
}

posicion Biblioteca {
X=380;
Y=50;
}

posicion Estante {
X=380;
Y=300;
}

posicion Catalogo {
X=700;
Y=50;
}

segmento (Libro, Recurso, 129, 244, 129, 200, 161, 200, 161, 145, herencia);
segmento (Estante, Biblioteca, 501, 244, 501, 200, 465, 200, 465, 164, composicion);
segmento (Catalogo, Biblioteca, 720, 102, 720, 165, 558, 165, 465, 165, 465, 164, agregacion);
segmento (Catalogo, Libro, 720, 126, 720, 400, 129, 400, 129, 368, dependencia);

abstracta clase Recurso {
atributos:
protegido string codigo;
protegido string titulo;
metodos:
publico string obtener_titulo();
}

clase Libro hereda Recurso {
atributos:
privado string autor;
privado int paginas;
metodos:
publico void prestar();
publico void devolver();
}

clase Biblioteca {
atributos:
privado string nombre;
privado string direccion;
metodos:
publico void abrir();
publico void cerrar();
}

clase Estante composicion Biblioteca {
atributos:
privado int numero;
privado string seccion;
metodos:
publico void ubicar(Libro libro);
}

clase Catalogo agregacion Biblioteca {
atributos:
privado int total_recursos;
metodos:
publico Libro buscar(string titulo);
}
