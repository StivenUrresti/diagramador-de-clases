Diagrama Tienda.

posicion Persona {
X=50;
Y=50;
}

posicion Cliente {
X=50;
Y=300;
}

posicion Pedido {
X=360;
Y=50;
}

posicion DetallePedido {
X=360;
Y=300;
}

posicion PasarelaPago {
X=680;
Y=50;
}

posicion Factura {
X=680;
Y=300;
}

segmento (Cliente, Persona, 120, 300, 120, 160, herencia);
segmento (Pedido, DetallePedido, 450, 160, 450, 300, composicion);
segmento (Pedido, Cliente, 360, 120, 190, 300, agregacion);
segmento (Pedido, PasarelaPago, 560, 120, 680, 120, dependencia);
segmento (Factura, Pedido, 680, 300, 450, 160, dependencia);

abstracta clase Persona {
atributos:
protegido string nombre;
protegido string documento;
metodos:
publico string identificar();
}

clase Cliente hereda Persona {
atributos:
privado string correo;
privado string telefono;
metodos:
publico void actualizar_contacto(string correo);
}

clase Pedido agregacion Cliente {
atributos:
privado int numero;
privado float total;
metodos:
publico void confirmar();
publico void cancelar();
}

clase DetallePedido composicion Pedido {
atributos:
privado int cantidad;
privado float precio_unitario;
metodos:
publico float subtotal();
}

clase PasarelaPago {
atributos:
privado string proveedor;
metodos:
publico bool cobrar(Pedido pedido);
}

clase Factura dependencia Pedido {
atributos:
privado string consecutivo;
privado float valor;
metodos:
publico void imprimir();
}
