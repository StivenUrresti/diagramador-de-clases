Diagrama Conectores.

posicion Entidad {
X=50;
Y=50;
}

posicion Usuario {
X=50;
Y=300;
}

posicion ServicioAutenticacion {
X=360;
Y=50;
}

posicion Perfil {
X=360;
Y=300;
}

posicion Sesion {
X=670;
Y=50;
}

segmento (Usuario, Entidad, 100, 250, 100, 120, herencia);
segmento (Usuario, ServicioAutenticacion, 230, 350, 360, 120, dependencia);
segmento (Usuario, Perfil, 230, 350, 360, 350, agregacion);
segmento (ServicioAutenticacion, Sesion, 560, 120, 670, 120, composicion);

abstracta clase Entidad {
atributos:
protegido int id;
protegido string fecha_creacion;
metodos:
publico int obtener_id();
}

clase Usuario hereda Entidad {
atributos:
privado string correo;
privado string clave;
metodos:
publico bool validar_clave(string clave);
}

clase ServicioAutenticacion {
atributos:
privado string proveedor;
metodos:
publico Sesion iniciar_sesion(Usuario usuario);
publico void cerrar_sesion(Sesion sesion);
}

clase Perfil agregacion Usuario {
atributos:
privado string nombre;
privado string avatar;
metodos:
publico void actualizar(string nombre);
}

clase Sesion composicion ServicioAutenticacion {
atributos:
privado string token;
privado int expira_en;
metodos:
publico bool esta_activa();
}
